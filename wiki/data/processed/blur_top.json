  "version": "Available since TouchDesigner 2018+",
  "lastUpdated": "2025-08-07T07:49:57.546Z",
  "sourceFile": "C:\\Program Files\\Derivative\\TouchDesigner\\Samples\\Learn\\OfflineHelp\\https.docs.derivative.ca\\Blur_TOP.htm",
  "url": "",
  "description": "The Blur TOP blurs the image with various kernel filters and radii. It can do multi-pass blurs and can do horizontal-only or vertical-only blurs.",
  "summary": "The Blur TOP blurs the image with various kernel filters and radii. It can do multi-pass blurs and can do horizontal-only or vertical-only blurs.",
  "details": "",
  "usage": "",
  "tips": [
    "Use Pre-Shrink to reduce resolution before blurring for better performance.",
    "Gaussian blur is the most common and natural-looking blur type.",
    "For real-time applications, keep blur size moderate - very large blurs are GPU-intensive."
  ],
  "warnings": [
    "Large blur sizes can significantly impact GPU performance. Consider using Pre-Shrink or lower resolution."
  ],
